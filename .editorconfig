root = true

[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8

[*.{sh,bash}]
# Shell files predate one repository-wide indent convention. Preserve each
# file's local style; safety reviews should not be obscured by reindent churn.
indent_style = unset
indent_size = unset

[Dockerfile]
indent_style = space
indent_size = 4

[*.{yml,yaml}]
indent_style = space
indent_size = 2

[*.{json,toml}]
indent_style = space
indent_size = 2

[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

# install.sh uses tabs because its heredocs (<<-) require tab indentation
[install.sh]
indent_style = tab

[Makefile]
indent_style = tab
